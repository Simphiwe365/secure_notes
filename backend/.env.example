# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-a-long-random-string-50-chars-min
DEBUG=False
ALLOWED_HOSTS=your-app.onrender.com,localhost,127.0.0.1

# ── Supabase PostgreSQL ────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → Database
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add your Vercel frontend URL here (no trailing slash)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
